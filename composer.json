{
    "name": "type-lang/parser",
    "type": "library",
    "description": "Library for parsing and validating TypeLang syntax and converting it into AST nodes",
    "keywords": ["parser", "language", "php", "phpdoc"],
    "license": "MIT",
    "support": {
        "source": "https://github.com/php-type-language/parser",
        "issues": "https://github.com/php-type-language/parser/issues"
    },
    "require": {
        "php": "^8.4",
        "type-lang/types": "^2.0",
        "phplrt/lexer": "^3.7",
        "phplrt/parser": "^3.7",
        "phplrt/source": "^3.7"
    },
    "autoload": {
        "psr-4": {
            "TypeLang\\Parser\\": "src"
        }
    },
    "require-dev": {
        "jetbrains/phpstorm-attributes": "^1.2",
        "phplrt/compiler": "^3.7.5",
        "phpstan/phpstan": "^2.2.5",
        "phpunit/phpunit": "^13.2.4"
    },
    "autoload-dev": {
        "psr-4": {
            "TypeLang\\Parser\\Tests\\": "tests"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-master": "2.x-dev",
            "dev-main": "2.x-dev"
        }
    },
    "config": {
        "sort-packages": true,
        "platform-check": true,
        "bin-compat": "full",
        "preferred-install": {
            "*": "dist"
        }
    },
    "scripts-aliases": {
        "test:unit": ["test", "phpunit", "unit"]
    },
    "scripts": {
        "test:unit": "phpunit --testdox"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
